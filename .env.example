# PhishLab Environment Configuration
# Copy to .env and adjust as needed.

# API
PHISHLAB_HOST=127.0.0.1
PHISHLAB_PORT=8000
PHISHLAB_DEBUG=true

# Database (SQLite for MVP)
PHISHLAB_DB_URL=sqlite:///./phishlab.db

# Upload limits
PHISHLAB_MAX_UPLOAD_SIZE_MB=10
PHISHLAB_UPLOAD_DIR=./uploads

# Logging
PHISHLAB_LOG_LEVEL=INFO

# Dashboard
VITE_API_URL=http://127.0.0.1:8000

# External integrations (opt-in, v0.2+)
# VIRUSTOTAL_API_KEY=your-vt-api-key-here
# GOOGLE_SAFE_BROWSING_KEY=your-gsb-api-key-here
